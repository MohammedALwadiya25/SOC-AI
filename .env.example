NODE_ENV=development
LOG_LEVEL=info

# MCP transport for version 1 is stdio.
MCP_SERVER_NAME=unified-soc-mcp
MCP_SERVER_VERSION=1.0.0

# Wazuh API
WAZUH_API_URL=https://wazuh.example.local:55000
WAZUH_API_USERNAME=readonly-user
WAZUH_API_PASSWORD=replace-me

# Wazuh Indexer / OpenSearch-compatible API
WAZUH_INDEXER_URL=https://wazuh-indexer.example.local:9200
WAZUH_INDEXER_USERNAME=readonly-indexer-user
WAZUH_INDEXER_PASSWORD=replace-me
WAZUH_INDEXER_ALERT_INDEX=wazuh-alerts-*
# For Docker Wazuh with archives enabled, use wazuh-archives-4.x-*
# For alert-based Zeek (if Wazuh rules tag Zeek events), use wazuh-alerts-*
WAZUH_INDEXER_ZEEK_INDEX=wazuh-archives-4.x-*
WAZUH_INDEXER_SURICATA_INDEX=wazuh-alerts-*

# Security defaults
TLS_REJECT_UNAUTHORIZED=true
HTTP_TIMEOUT_MS=10000
HTTP_RETRY_ATTEMPTS=2
HTTP_RETRY_BASE_DELAY_MS=250
DEFAULT_LIMIT=50
MAX_LIMIT=500
DEFAULT_TIME_RANGE_HOURS=24

# Optional LLM reasoning.
# Leave disabled if you only want deterministic JSON summaries.
LLM_PROVIDER=disabled
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=replace-me
LLM_MODEL=replace-with-your-model
LLM_TIMEOUT_MS=20000
